# =============================================================================
# SmileCare Dental AI Voice Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before running.

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Vapi.ai (voice call handling)
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

# Cal.com (appointment scheduling)
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID_NEW_PATIENT=
CALCOM_EVENT_TYPE_ID_CLEANING=
CALCOM_EVENT_TYPE_ID_EMERGENCY=
CALCOM_EVENT_TYPE_ID_CONSULTATION=
CALCOM_USERNAME=

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://dental_user:dental_pass@localhost:5433/dental_agent

# App settings
ESCALATION_PHONE_NUMBER=
OFFICE_TIMEZONE=America/Chicago
OFFICE_NAME=SmileCare Dental
DEMO_MODE=true

# Server (used for Vapi webhook URL)
# For local dev: http://localhost:8000
# For Vapi webhooks: run `ssh -R 80:localhost:8000 nokey@localhost.run`
#   then paste the https://...lhr.life URL here
SERVER_BASE_URL=http://localhost:8000
