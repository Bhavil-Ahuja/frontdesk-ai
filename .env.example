# =============================================================================
# Scheduler.ai — Multi-Tenant AI Voice Agent Platform — Environment Config
# =============================================================================
# Copy this file to .env and fill in all values before running.

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Vapi.ai (voice call handling)
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://scheduler_user:scheduler_pass@localhost:5432/scheduler_ai

# App settings
ESCALATION_PHONE_NUMBER=
OFFICE_TIMEZONE=America/Chicago
OFFICE_NAME=Scheduler.ai
DEMO_MODE=true

# Server (used for Vapi webhook URL)
# For local dev: http://localhost:8000
# For Vapi webhooks: run `ssh -R 80:localhost:8000 nokey@localhost.run`
#   then paste the https://...lhr.life URL here
SERVER_BASE_URL=http://localhost:8000
